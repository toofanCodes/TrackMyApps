{
  "manifest_version": 3,
  "name": "Job Tracker with Kanban Dashboard",
  "version": "1.0",
  "description": "Extract job information from web pages and generate daily Excel reports",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads",
    "contextMenus",
    "alarms",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [

    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Info Saver"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 